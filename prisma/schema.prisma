generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "debian-openssl-1.1.x"]
    output = "../node_modules/.prisma/client"
}

generator dbml {
    provider = "prisma-dbml-generator"
}

// datasource db {
    // provider = "sqlserver"
    // url      = env("DATABASE_URL")
// }

datasource db {
  provider  = "postgresql"
  url  	    = env("PG_DATABASE_URL")
  // uncomment next line if you use Prisma <5.10
  // directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
    id              Int      @id @default(autoincrement())

    role_id         Int?      
    role            Role?   @relation(fields: [role_id], references: [id])

    package_id      Int?      
    package         Package?   @relation(fields: [package_id], references: [id])

    status_id       Int?      
    status          Status?    @relation(fields: [status_id], references: [id])

    agency_id       Int?      
    agency          Agency?    @relation(fields: [agency_id], references: [id])

    tax_id_no       String
    username        String
    password        String
    first_name      String
    last_name       String
    birth_date      DateTime    
    phone_number    String 
    email           String   @unique
    created_at      DateTime?    @default(now())
    updated_at      DateTime? 

    property        Property[] 
    favourite       Favourite[] 
    user_agent      User_Agent[] 
    user_role       User_Role[]  
    notification    Notification[]  
}

model User_Role {
    id              Int      @id @default(autoincrement())
    role_id         Int      
    role            Role?   @relation(fields: [role_id], references: [id]) 
    user_id         Int      
    user            User?    @relation(fields: [user_id], references: [id])
}

model Role {
    id              Int      @id @default(autoincrement())
    role_name       String
    users           User[]   
    user_role       User_Role[]   
}

model Package {
    id              Int      @id @default(autoincrement())
    package_name    String
    user            User[] 
}

model Status {
    id              Int      @id @default(autoincrement())
    status_name     String
    user            User[]  
    property            Property[]  
}

model Agency {
    id              Int      @id @default(autoincrement())
    agency_id       String   @unique
    agency_name     String
    tax_id_no       String
    phone_number    String 
    address         String
    province        String
    district        String
    postcode        Int
    
    user            User[]  
    user_agent      User_Agent[]  
    notification    Notification[]  
}

model User_Agent {
    id              Int      @id @default(autoincrement())
    user_id         Int      
    user            User?    @relation(fields: [user_id], references: [id])
    agency_id       Int      
    agency          Agency?    @relation(fields: [agency_id], references: [id])  

    created_at      DateTime    @default(now())
    updated_at      DateTime
}

model Notification {
    id              Int      @id @default(autoincrement())
    property_id     Int?
    user_id         Int?      
    user            User?    @relation(fields: [user_id], references: [id])
    agency_id       Int?      
    agency          Agency?    @relation(fields: [agency_id], references: [id])   
    message         String
    is_read         Boolean
    created_at      DateTime         @default(now())
    updated_at      DateTime  
}

model Favourite {
    id              Int      @id @default(autoincrement())
    user_id         Int      
    user            User?    @relation(fields: [user_id], references: [id]) 

    is_favourite    Boolean
    buyer_id        Int 
    property_id     Int 
    created_at      DateTime         @default(now())
    updated_at      DateTime
}

model Property_Type {
    property_type_id        Int      @id @default(autoincrement())
    property_type           String
}

model Property {
    id                      Int      @id @default(autoincrement())
    title_deed_id           Int

    status_id               Int
    status                  Status?    @relation(fields: [status_id], references: [id])

    property_type_id        Int

    seller_id               Int
    user                    User?    @relation(fields: [seller_id], references: [id]) 


    unit_id                 Int
    units                   Units?    @relation(fields: [unit_id], references: [id])

    property_name           String
    description             String
    price                   Int
    latitude                Float
    longitude               Float
    land_area_rai           Decimal @db.Decimal(10,2)
    land_area_ngan          Decimal @db.Decimal(10,2)
    land_area_square_wa     Decimal @db.Decimal(10,2)
    usable_size_square_m    Decimal @db.Decimal(10,2)
    bedroom                 Int?
    bathroom                Int?
    kitchen                 Int?
    floors                  Int?
    view_count              Int?
    created_at              DateTime    @default(now())     
    updated_at              DateTime
}

model Units {
    id                  Int      @id @default(autoincrement())
    unit_name           String
    unit_type           String
    conversion_factor   Decimal @db.Decimal(10,2)
    created_at          DateTime    @default(now())     
    updated_at          DateTime

    property            Property[]
}

model Appointment {
    id                  Int      @id @default(autoincrement())
    app_status          String
    app_date            DateTime
    start_time          DateTime
    end_time            DateTime
    location            String
    created_at          DateTime    @default(now())     
    updated_at          DateTime
}

model User_Appointment {
    id                  Int      @id @default(autoincrement())
    appointment_id      Int
    buyer_id            Int
    seller_id           Int
    created_at          DateTime    @default(now())     
    updated_at          DateTime
}



