generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

generator dbml {
  provider = "prisma-dbml-generator"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  id        Int    @id @default(autoincrement())
  password  String
  firstName String
  lastName  String
  email     String @unique
  mobile    String @unique
}
